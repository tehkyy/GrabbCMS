{
  "hosting": {
    "site": "grabbit-370315",
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "emulators": {
      "auth": {
        "port": 9099
      },
      "functions": {
        "port": 5001
      },
      "firestore": {
        "port": 8080
      },
      "database": {
        "port": 9999
      },
      "ui": {
        "enabled": true
      },
      "singleProjectMode": true,
      "storage": {
        "port": 9199
      }
    },
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
